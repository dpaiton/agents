    { "measurement": "Dorsal fin height",                      "ratio": 0.07, "absolute_meters": 0.8  }
  ],

  "geometry": [
    {
      "name": "Fuselage",
      "count": 1,
      "primitive": "cube",
      "dimensions_box": { "width": 2.5, "length": 12.0, "height": 1.8 },
      "tapers": [
        { "face": "front", "scale_width": 0.4, "scale_height": 0.6 },
        { "face": "rear",  "scale_width": 0.8 }
      ],
      "modifiers": [
        { "type": "subdivision", "level": 1 },
        { "type": "bevel", "width": 0.02 }
      ],
      "notes": "Rectangular cross-section with beveled edges. Subdivision level 1 keeps angular silhouette."
    },
    {
      "name": "Wings",
      "count": 4,
      "primitive": "cube",
      "dimensions_box": { "width": 4.0, "length": 1.5, "height": 0.15 },
      "position": {
        "attachment_point": "mid-fuselage",
        "longitudinal_fraction": 0.6
      },
      "angular_offsets": [
        { "label": "upper-right",  "angle_degrees":   30 },
        { "label": "upper-left",   "angle_degrees":  150 },
        { "label": "lower-right",  "angle_degrees":  -30 },
        { "label": "lower-left",   "angle_degrees": -150 }
      ],
      "sweep": {
        "target": "tips",
        "offset": { "x": 0.0, "y": -0.8, "z": 0.0 }
      },
      "tapers": [
        { "face": "front", "scale_width": 0.5 }
      ],
      "modifiers": [
        { "type": "bevel", "width": 0.01 }
      ],
      "notes": "Cruciform X-configuration. Tip chord ~50% of root chord. Tips swept 0.8m rearward."
    },
    {
      "name": "Engine nacelles",
      "count": 2,
      "primitive": "cylinder",
      "dimensions_cylinder": { "radius": 0.6, "depth": 4.0 },
      "position": {
        "attachment_point": "fuselage_rear",
        "offset": { "x": 0.75, "y": -1.0, "z": 0.0 }
      },
      "notes": "Side-by-side, horizontally centered. Nacelle centers ~1.5m apart. Rear extends ~1.0m beyond fuselage.",
      "sub_components": [
        {
          "name": "Nacelle body",
          "count": 1,
          "primitive": "cylinder",
          "dimensions_cylinder": { "radius": 0.6, "depth": 4.0 },
          "notes": "Main cylinder body with dark panels material."
        },
        {
          "name": "Rear nozzle ring",
          "count": 1,
          "primitive": "torus",
          "major_radius": 0.6,
          "minor_radius": 0.06,
          "position": {
            "attachment_point": "nacelle_rear"
          },
          "notes": "Torus at rear of nacelle."
        },
        {
          "name": "Exhaust glow",
          "count": 1,
          "primitive": "circle",
          "radius": 0.54,
          "position": {
            "attachment_point": "nacelle_rear"
          },
          "notes": "Circle fill (ngon), radius 0.9x nacelle radius, emission material."
        },
        {
          "name": "Forward intake ring",
          "count": 1,
          "primitive": "torus",
          "major_radius": 0.55,
          "minor_radius": 0.05,
          "position": {
            "attachment_point": "nacelle_front"
          },
          "notes": "Slightly smaller than main body."
        },
        {
          "name": "Detail rings",
          "count": 3,
          "primitive": "torus",
          "major_radius": 0.6,
          "minor_radius": 0.03,
          "notes": "2-3 segmented detail rings along nacelle length."
        }
      ]
    },
    {
      "name": "Weapon barrels",
      "count": 4,
      "primitive": "cylinder",
      "dimensions_cylinder": { "radius": 0.06, "depth": 2.5 },
      "position": {
        "attachment_point": "wing_tip"
      },
      "notes": "Extends forward from each wing tip, parallel to fuselage longitudinal axis.",
      "sub_components": [
        {
          "name": "Weapon tip sphere",
          "count": 1,
          "primitive": "sphere",
          "radius": 0.08,
          "position": {
            "attachment_point": "barrel_forward_end"
          },
          "notes": "Small sphere at forward end with red emission material."
        }
      ]
    },
    {
      "name": "Cockpit canopy",
      "count": 1,
      "primitive": "cube",
      "dimensions_box": { "width": 0.6, "length": 2.0, "height": 0.35 },
      "position": {
        "attachment_point": "fuselage_top",
        "longitudinal_fraction": 0.33
      },
      "tapers": [
        { "face": "front", "scale_width": 0.4 }
      ],
      "modifiers": [
        { "type": "subdivision", "level": 1 }
      ],
      "notes": "Angular canopy on top of fuselage, centered laterally, forward 1/3 of fuselage length."
    },
    {
      "name": "Dorsal fin",
      "count": 1,
      "primitive": "cube",
      "dimensions_box": { "width": 0.06, "length": 2.0, "height": 0.8 },
      "position": {
        "attachment_point": "fuselage_top",
        "offset": { "x": 0.0, "y": 0.0, "z": 0.0 }
      },
      "sweep": {
        "target": "top_edge",
        "offset": { "x": 0.0, "y": -0.5, "z": 0.0 }
      },
      "tapers": [
        { "face": "top", "scale_length": 0.5 }
      ],
      "notes": "Top of fuselage, directly behind cockpit. Top edge shifted 0.5m rearward. Tip tapered to 50% length."
    }
  ],

