  "proportions_reference": [
    { "measurement": "Fuselage length",                        "ratio": 1.00, "absolute_meters": 12.0 },
    { "measurement": "Fuselage width",                         "ratio": 0.21, "absolute_meters": 2.5  },
    { "measurement": "Fuselage height",                        "ratio": 0.15, "absolute_meters": 1.8  },
    { "measurement": "Wingspan (tip-to-tip)",                  "ratio": 0.83, "absolute_meters": 10.0 },
