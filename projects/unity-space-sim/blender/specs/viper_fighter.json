  "lod_strategy": {
    "method": "decimate",
    "levels": [
      { "level": 0, "target_triangles": 5000 },
      { "level": 1, "target_triangles": 2000, "decimation_ratio": 0.40 },
      { "level": 2, "target_triangles": 750,  "decimation_ratio": 0.15 }
    ]
  },

  "generation_script": {
    "location": "projects/unity-space-sim/blender/scripts/generate_viper_fighter.py",
    "usage": [
      "blender --background --python generate_viper_fighter.py",
      "blender --background --python generate_viper_fighter.py -- --output-dir /path/to/output"
    ],
    "output_files": [
      { "filename": "viper_fighter_LOD0.fbx", "description": "Main high-detail model" },
      { "filename": "viper_fighter_LOD1.fbx", "description": "Medium distance version" },
      { "filename": "viper_fighter_LOD2.fbx", "description": "Low detail for far distances" },
      { "filename": "viper_fighter_3quarter.png", "description": "3/4 view render (compare against hero.png)" },
      { "filename": "viper_fighter_side.png", "description": "Side profile render (compare against side.png)" }
    ],
    "validation": {
      "command": "python projects/unity-space-sim/tools/validate_visual.py --render-dir assets/generated/viper-fighter/ --concept-dir assets/drafts/fighter-v4/ --threshold 0.75",
      "threshold": 0.75
    }
  },

  "required_script_changes": [
    "Wings: Replace create_wings() (2 flat swept-back planes) with 4 wings in cruciform X-configuration at +/-30 degree angular offsets",
    "Engines: Replace create_engines() (4 small quad cylinders) with 2 large cylindrical nacelles side-by-side",
    "Remove: Delete create_chin_guns() -- not in concept art",
    "Remove: Delete create_underslung_turret() -- not in concept art",
    "Fuselage: Update ViperConfig dimensions from 14m x 2m x 1.4m to 12m x 2.5m x 1.8m",
    "Fuselage subdivision: Keep at level 1 for angular silhouette",
    "Update: apply_materials() for new component set (no turret/chin gun materials)",
    "Update: join_fighter_parts() for new component dictionary"
  ]
}
